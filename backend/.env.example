MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net
MONGO_DB=pharma_mapping
JWT_SECRET=replace-with-a-long-random-string-32chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
APP_HOST=127.0.0.1
APP_PORT=8000

# ---- Security knobs (prod) ----
# "prod" hides /docs, /redoc, /openapi.json and enables HSTS.
ENV=dev
# When false (recommended in prod), /api/auth/register requires an invite
# — the public endpoint returns 403. The first user is always allowed.
ALLOW_OPEN_REGISTRATION=true
# Fernet key used to encrypt per-team Pipedrive API keys at rest.
# Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=
